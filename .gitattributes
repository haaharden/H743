# 默认所有文本文件在仓库中使用 LF
* text=auto eol=lf

# C/C++ 源码统一 LF
*.c   text eol=lf
*.h   text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf

# 脚本
*.sh  text eol=lf
*.py  text eol=lf

# Windows 脚本使用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件不做换行转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.bin binary
*.hex binary
*.axf binary
*.elf binary
*.o   binary
*.a   binary